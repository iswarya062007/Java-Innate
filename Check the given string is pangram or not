import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter a string : ");
        String str = sc.nextLine();
        
        // 1. Convert to lowercase so we don't have to check capital letters separately
        str = str.toLowerCase();
        
        int count = 0;
        
        // 2. Loop through every letter of the alphabet from 'a' to 'z'
        for (char ch = 'a'; ch <= 'z'; ch++) {
            
            // 3. Check if the user's string contains the current alphabet letter
            if (str.contains("" + ch)) {
                count++; // Increase count if the letter is found
            }
        }
        
        // 4. If count is 26, it means all letters from a-z were found
        if (count == 26) {
            System.out.println("The string is a Pangram.");
        } else {
            System.out.println("The string is NOT a Pangram.");
        }
    }
}
